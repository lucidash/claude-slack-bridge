# Slack 설정
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack 모드: http (기본, Events API + Public URL 필요) | socket (Socket Mode, App-Level Token 필요)
SLACK_MODE=http

# HTTP 모드용 — Slack Events API 서명 검증 시크릿
SLACK_SIGNING_SECRET=your-signing-secret

# Socket 모드용 — App-Level Token (xapp- 로 시작, Slack App 설정에서 발급)
# 발급 방법: api.slack.com/apps → Basic Information → App-Level Tokens → connections:write 스코프
SLACK_APP_TOKEN=xapp-your-app-token

# 허용된 Slack 사용자 ID (콤마 구분)
ALLOWED_USERS=U0XXXXXXXX,U0YYYYYYYY

# 서버 설정 (HTTP 모드: webhook 수신 / Socket 모드: 디버그 엔드포인트만 노출)
PORT=3005

# Claude Code 설정
CLAUDE_MODEL=opus
CLAUDE_ALLOWED_DIRS=~/projects
CLAUDE_SKIP_PERMISSIONS=true

# OpenAI API Key (STT용)
OPENAI_API_KEY=sk-your-openai-api-key
